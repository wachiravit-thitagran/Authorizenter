{
    "name": "autorizenter/autorizenter",
    "description": "Flexible OAuth2/OIDC Single Sign-On for WordPress with organization restriction and customizable post-login questions.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "oauth2", "oidc", "sso", "login", "google", "line", "facebook"],
    "require": {
        "php": ">=8.0",
        "firebase/php-jwt": "^7.0",
        "jumbojett/openid-connect-php": "^1.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "platform": {
            "php": "8.0"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml.dist plugins/",
        "lint:fix": "phpcbf --standard=phpcs.xml.dist plugins/",
        "test": "phpunit",
        "syntax": "find plugins tests -name '*.php' -print0 | xargs -0 -n1 -P4 php -l"
    }
}
