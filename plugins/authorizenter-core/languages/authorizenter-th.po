msgid "(all) or comma-separated question ids"
msgstr "(ทั้งหมด) หรือรหัสคำถามคั่นด้วยจุลภาค"

msgid "(blank)"
msgstr "(ว่าง)"

msgid "(inherit global)"
msgstr "(ใช้ค่ากลาง)"

msgid "A few questions"
msgstr "คำถามเพิ่มเติม"

msgid "Access control"
msgstr "การควบคุมการเข้าถึง"

msgid "Access control (per user / domain)"
msgstr "การควบคุมการเข้าถึง (รายผู้ใช้ / โดเมน)"

msgid "Administrator bypass"
msgstr "ให้ผู้ดูแลระบบข้ามข้อจำกัด"

msgid "Allow administrators to still use a password (recommended — prevents lockout if SSO breaks)."
msgstr "อนุญาตให้ผู้ดูแลระบบยังใช้รหัสผ่านได้ (แนะนำ เพื่อป้องกันการถูกล็อกออกเมื่อ SSO มีปัญหา)"

msgid "Allow sign-in with this provider"
msgstr "อนุญาตให้เข้าสู่ระบบด้วยผู้ให้บริการนี้"

msgid "Allowed domains"
msgstr "โดเมนที่อนุญาต"

msgid "Allowed email domains"
msgstr "โดเมนอีเมลที่อนุญาต"

msgid "Always denied, regardless of any other setting."
msgstr "ปฏิเสธเสมอ ไม่ว่าการตั้งค่าอื่นจะเป็นอย่างไร"

msgid "Answer"
msgstr "คำตอบ"

msgid "Answered"
msgstr "ตอบแล้ว"

msgid "Approved"
msgstr "อนุมัติแล้ว"

msgid "Attach logins to an existing user with the same verified email."
msgstr "เชื่อมการเข้าสู่ระบบกับผู้ใช้เดิมที่มีอีเมลที่ยืนยันแล้วตรงกัน"

msgid "Auto-provision"
msgstr "สร้างผู้ใช้อัตโนมัติ"

msgid "Authorizenter"
msgstr "Authorizenter"

msgid "Authorizenter Login"
msgstr "เข้าสู่ระบบด้วย Authorizenter"

msgid "Authorizenter Logout"
msgstr "ออกจากระบบด้วย Authorizenter"

msgid "Authorizenter Report"
msgstr "รายงาน Authorizenter"

msgid "Authorizenter UI requires Authorizenter Core to be installed and active."
msgstr "Authorizenter UI ต้องติดตั้งและเปิดใช้งาน Authorizenter Core ก่อน"

msgid "Back to summary"
msgstr "กลับไปหน้าสรุป"

msgid "Block WordPress username/password login and force single sign-on."
msgstr "ปิดการเข้าสู่ระบบด้วยชื่อผู้ใช้/รหัสผ่านของ WordPress และบังคับใช้ SSO"

msgid "Block message"
msgstr "ข้อความเมื่อถูกบล็อก"

msgid "Blocked"
msgstr "บล็อกแล้ว"

msgid "Breakdown"
msgstr "รายละเอียดแยกย่อย"

msgid "Button label"
msgstr "ป้ายกำกับปุ่ม"

msgid "Client ID"
msgstr "Client ID"

msgid "Client Secret"
msgstr "Client Secret"

msgid "Context"
msgstr "บริบท"

msgid "Continue"
msgstr "ดำเนินการต่อ"

msgid "Continue with %s"
msgstr "ดำเนินการต่อด้วย %s"

msgid "Could not fetch provider signing keys."
msgstr "ไม่สามารถดึง signing keys ของผู้ให้บริการได้"

msgid "Could not read user profile."
msgstr "ไม่สามารถอ่านโปรไฟล์ผู้ใช้ได้"

msgid "Create a WordPress user automatically on first login."
msgstr "สร้างผู้ใช้ WordPress ให้อัตโนมัติเมื่อเข้าสู่ระบบครั้งแรก"

msgid "Default role"
msgstr "บทบาทเริ่มต้น"

msgid "Deny redirect"
msgstr "ปลายทางเมื่อถูกปฏิเสธ"

msgid "Disable password sign-in"
msgstr "ปิดการเข้าสู่ระบบด้วยรหัสผ่าน"

msgid "Discovery URL"
msgstr "Discovery URL"

msgid "Email"
msgstr "อีเมล"

msgid "Enabled"
msgstr "เปิดใช้งาน"

msgid "Enforce organization policy"
msgstr "บังคับใช้นโยบายองค์กร"

msgid "Enforce policy"
msgstr "บังคับใช้นโยบาย"

msgid "Export all answers (CSV)"
msgstr "ส่งออกคำตอบทั้งหมด (CSV)"

msgid "Facebook"
msgstr "Facebook"

msgid "Facebook returned no access token."
msgstr "Facebook ไม่ส่ง access token กลับมา"

msgid "Fallback when a context denies access and has no deny_redirect of its own. If empty, users return to the context login page with an error."
msgstr "ปลายทางสำรองเมื่อบริบทปฏิเสธการเข้าถึงและไม่ได้ตั้งค่า deny_redirect ไว้ หากเว้นว่าง ผู้ใช้จะกลับไปหน้าเข้าสู่ระบบของบริบทนั้นพร้อมข้อความผิดพลาด"

msgid "For Google: require the Workspace hosted-domain claim to match."
msgstr "สำหรับ Google: บังคับให้ค่า hosted-domain claim ของ Workspace ตรงกัน"

msgid "Global deny redirect"
msgstr "ปลายทางกลางเมื่อถูกปฏิเสธ"

msgid "Google"
msgstr "Google"

msgid "ID (slug)"
msgstr "รหัส (slug)"

msgid "ID token audience mismatch."
msgstr "audience ของ ID token ไม่ตรงกัน"

msgid "ID token issuer mismatch."
msgstr "issuer ของ ID token ไม่ตรงกัน"

msgid "ID token nonce mismatch."
msgstr "nonce ของ ID token ไม่ตรงกัน"

msgid "Identities from these providers bypass domain checks (e.g. your own org IdP)."
msgstr "ตัวตนจากผู้ให้บริการเหล่านี้จะข้ามการตรวจสอบโดเมน (เช่น IdP ขององค์กรคุณเอง)"

msgid "Inherit global"
msgstr "ใช้ค่ากลาง"

msgid "Inherit global policy"
msgstr "ใช้ค่านโยบายกลาง"

msgid "Insufficient permissions."
msgstr "สิทธิ์ไม่เพียงพอ"

msgid "Invalid ID token signature."
msgstr "ลายเซ็นของ ID token ไม่ถูกต้อง"

msgid "Invalid OIDC discovery document."
msgstr "เอกสาร OIDC discovery ไม่ถูกต้อง"

msgid "LINE"
msgstr "LINE"

msgid "Label"
msgstr "ป้ายกำกับ"

msgid "Leave all unchecked to ask everyone regardless of login method."
msgstr "ไม่ต้องเลือกอะไรหากต้องการถามทุกคนไม่ว่าจะเข้าสู่ระบบด้วยวิธีใด"

msgid "Leave all unchecked to show every enabled provider."
msgstr "ไม่ต้องเลือกอะไรหากต้องการแสดงผู้ให้บริการที่เปิดใช้งานทั้งหมด"

msgid "Limit to providers"
msgstr "จำกัดเฉพาะผู้ให้บริการ"

msgid "Link by verified email"
msgstr "เชื่อมด้วยอีเมลที่ยืนยันแล้ว"

msgid "Lock out an IP after repeated failed password attempts (brute-force protection)."
msgstr "ล็อก IP หลังจากพยายามเข้าสู่ระบบด้วยรหัสผ่านผิดซ้ำหลายครั้ง (ป้องกัน brute force)"

msgid "Lockout (seconds)"
msgstr "เวลาล็อก (วินาที)"

msgid "Login context id, e.g. default or admin."
msgstr "รหัสบริบทเข้าสู่ระบบ เช่น default หรือ admin"

msgid "Login contexts"
msgstr "บริบทการเข้าสู่ระบบ"

msgid "Login security"
msgstr "ความปลอดภัยการเข้าสู่ระบบ"

msgid "Login session expired or invalid. Please try again."
msgstr "เซสชันการเข้าสู่ระบบหมดอายุหรือไม่ถูกต้อง กรุณาลองอีกครั้ง"

msgid "Login settings"
msgstr "การตั้งค่าการเข้าสู่ระบบ"

msgid "Logo URL"
msgstr "URL โลโก้"

msgid "Logout settings"
msgstr "การตั้งค่าการออกจากระบบ"

msgid "Max attempts"
msgstr "จำนวนครั้งสูงสุด"

msgid "Missing authorization parameters."
msgstr "ไม่มีพารามิเตอร์ authorization ที่จำเป็น"

msgid "Name"
msgstr "ชื่อ"

msgid "Named login profiles. Place a context on any page with [authorizenter_login context=\"id\"]. Each context can show a subset of providers, apply its own policy, require a capability, and redirect differently."
msgstr "โปรไฟล์การเข้าสู่ระบบแบบตั้งชื่อได้ วางบริบทบนหน้าใดก็ได้ด้วย [authorizenter_login context=\"id\"] แต่ละบริบทสามารถเลือกผู้ให้บริการเฉพาะกลุ่ม ใช้นโยบายของตัวเอง บังคับ capability และ redirect ต่างกันได้"

msgid "New context"
msgstr "บริบทใหม่"

msgid "New question"
msgstr "คำถามใหม่"

msgid "No"
msgstr "ไม่ใช่"

msgid "No OIDC discovery URL configured."
msgstr "ยังไม่ได้ตั้งค่า OIDC discovery URL"

msgid "No matching account exists and self-registration is disabled."
msgstr "ไม่พบบัญชีที่ตรงกัน และปิดการสมัครด้วยตนเองไว้"

msgid "No questions are configured yet."
msgstr "ยังไม่ได้ตั้งค่าคำถาม"

msgid "No respondents."
msgstr "ไม่มีผู้ตอบ"

msgid "No responses"
msgstr "ไม่มีคำตอบ"

msgid "No sign-in methods are configured yet."
msgstr "ยังไม่ได้ตั้งค่าวิธีเข้าสู่ระบบ"

msgid "No — existing accounts only"
msgstr "ไม่ — เฉพาะบัญชีที่มีอยู่แล้ว"

msgid "OIDC discovery URL must use HTTPS."
msgstr "OIDC discovery URL ต้องใช้ HTTPS"

msgid "Off — allow any authenticated user"
msgstr "ปิด — อนุญาตผู้ใช้ที่ยืนยันตัวตนแล้วทุกคน"

msgid "On — apply domain/verified/hd checks"
msgstr "เปิด — ตรวจสอบโดเมน อีเมลที่ยืนยันแล้ว และ hd claim"

msgid "One domain per line (or comma-separated). Subdomains are matched. Leave empty to allow any domain."
msgstr "หนึ่งโดเมนต่อบรรทัด (หรือคั่นด้วยจุลภาค) ระบบจะรวมโดเมนย่อยด้วย เว้นว่างเพื่ออนุญาตทุกโดเมน"

msgid "One email or domain per line. Domains match subdomains too."
msgstr "หนึ่งอีเมลหรือโดเมนต่อบรรทัด โดเมนจะครอบคลุมโดเมนย่อยด้วย"

msgid "One option per line"
msgstr "หนึ่งตัวเลือกต่อบรรทัด"

msgid "One rule per line: \"matcher = role\". Matchers: domain:, provider:, email:, or *. First match wins; otherwise the default role applies (new users only)."
msgstr "หนึ่งกฎต่อบรรทัด: \"matcher = role\" matcher ใช้ได้คือ domain:, provider:, email: หรือ * กฎแรกที่ตรงจะถูกใช้ มิฉะนั้นจะใช้บทบาทเริ่มต้น (เฉพาะผู้ใช้ใหม่)"

msgid "Only identities on the approved list may sign in. Others are recorded as pending."
msgstr "อนุญาตให้เข้าสู่ระบบเฉพาะตัวตนที่อยู่ในรายการอนุมัติ รายอื่นจะถูกบันทึกเป็นรออนุมัติ"

msgid "Optional. Shown on the SSO button instead of the default lock icon (square image, e.g. 20×20 SVG or PNG)."
msgstr "ไม่บังคับ แสดงบนปุ่ม SSO แทนไอคอนล็อกเริ่มต้น (ภาพสี่เหลี่ยม เช่น SVG หรือ PNG ขนาด 20×20)"

msgid "Options"
msgstr "ตัวเลือก"

msgid "Organization policy"
msgstr "นโยบายองค์กร"

msgid "Password sign-in is disabled for this site. Please sign in with single sign-on."
msgstr "ไซต์นี้ปิดการเข้าสู่ระบบด้วยรหัสผ่าน กรุณาเข้าสู่ระบบด้วย single sign-on"

msgid "Pending approval"
msgstr "รออนุมัติ"

msgid "Please answer: %s"
msgstr "กรุณาตอบ: %s"

msgid "Please sign in first."
msgstr "กรุณาเข้าสู่ระบบก่อน"

msgid "Post-login questions. Each question is a fieldset; leave a blank row's ID empty to ignore it. Options apply to radio/select only (one per line)."
msgstr "คำถามหลังเข้าสู่ระบบ แต่ละคำถามเป็นชุดฟิลด์ เว้น ID ของแถวว่างไว้เพื่อข้ามแถวนั้น ตัวเลือกใช้กับ radio/select เท่านั้น (หนึ่งตัวเลือกต่อบรรทัด)"

msgid "Private site"
msgstr "ไซต์ส่วนตัว"

msgid "Provider returned no usable identity."
msgstr "ผู้ให้บริการไม่ส่งตัวตนที่ใช้ได้กลับมา"

msgid "Providers"
msgstr "ผู้ให้บริการ"

msgid "Question"
msgstr "คำถาม"

msgid "Questions"
msgstr "คำถาม"

msgid "Redirect after login"
msgstr "เปลี่ยนเส้นทางหลังเข้าสู่ระบบ"

msgid "Register this redirect / callback URL with each provider:"
msgstr "ลงทะเบียน redirect / callback URL นี้กับผู้ให้บริการแต่ละราย:"

msgid "Reject providers that do not assert a verified email (when domains are set)."
msgstr "ปฏิเสธผู้ให้บริการที่ไม่ยืนยันว่าอีเมลผ่านการตรวจสอบแล้ว (เมื่อมีการตั้งค่าโดเมน)"

msgid "Require Google hd claim"
msgstr "บังคับใช้ Google hd claim"

msgid "Require login to view any front-end content (anonymous visitors are redirected to sign in)."
msgstr "ต้องเข้าสู่ระบบก่อนดูเนื้อหาหน้าเว็บทั้งหมด (ผู้เยี่ยมชมที่ไม่ระบุตัวตนจะถูกส่งไปหน้าเข้าสู่ระบบ)"

msgid "Require verified email"
msgstr "บังคับใช้อีเมลที่ยืนยันแล้ว"

msgid "Required"
msgstr "บังคับ"

msgid "Required capability"
msgstr "Capability ที่ต้องมี"

msgid "Restrict sign-in using the rules below. When off, any authenticated user is allowed (capability checks per context still apply)."
msgstr "จำกัดการเข้าสู่ระบบด้วยกฎด้านล่าง เมื่อปิดอยู่ ผู้ใช้ที่ยืนยันตัวตนแล้วทุกคนจะเข้าได้ (ยังตรวจ capability ตามบริบท)"

msgid "Restrict to approved list"
msgstr "จำกัดเฉพาะรายการที่อนุมัติ"

msgid "Role mapping"
msgstr "การกำหนดบทบาท"

msgid "SSO"
msgstr "SSO"

msgid "SSO sign-in buttons for a login context."
msgstr "ปุ่มเข้าสู่ระบบ SSO สำหรับบริบทการเข้าสู่ระบบ"

msgid "Scopes"
msgstr "Scopes"

msgid "Set \"No\" for privileged contexts so only pre-existing accounts can enter."
msgstr "ตั้งเป็น \"ไม่\" สำหรับบริบทที่มีสิทธิ์สูง เพื่อให้เฉพาะบัญชีที่มีอยู่แล้วเข้าได้"

msgid "Settings saved."
msgstr "บันทึกการตั้งค่าแล้ว"

msgid "Settings sections"
msgstr "หมวดการตั้งค่า"

msgid "Sign in"
msgstr "เข้าสู่ระบบ"

msgid "Sign out"
msgstr "ออกจากระบบ"

msgid "Sign-in could not be completed. Please try again."
msgstr "ไม่สามารถเข้าสู่ระบบให้เสร็จสมบูรณ์ได้ กรุณาลองอีกครั้ง"

msgid "Sign-out link (supports SSO logout)."
msgstr "ลิงก์ออกจากระบบ (รองรับการออกจากระบบ SSO)"

msgid "Submit"
msgstr "ส่ง"

msgid "Thanks — nothing else is needed."
msgstr "ขอบคุณ ไม่ต้องดำเนินการเพิ่มเติม"

msgid "The firebase/php-jwt library is required for OIDC verification. Run composer install."
msgstr "ต้องใช้ไลบรารี firebase/php-jwt สำหรับการตรวจสอบ OIDC กรุณารัน composer install"

msgid "The question shown to users"
msgstr "คำถามที่แสดงให้ผู้ใช้เห็น"

msgid "This sign-in method is not available here."
msgstr "วิธีเข้าสู่ระบบนี้ใช้กับที่นี่ไม่ได้"

msgid "This sign-in method is not available."
msgstr "วิธีเข้าสู่ระบบนี้ยังไม่พร้อมใช้งาน"

msgid "This site uses single sign-on. Password login is disabled."
msgstr "ไซต์นี้ใช้ single sign-on และปิดการเข้าสู่ระบบด้วยรหัสผ่าน"

msgid "Throttle failed logins"
msgstr "จำกัดการเข้าสู่ระบบที่ล้มเหลว"

msgid "Tick to approve and save. Unticked entries remain pending."
msgstr "เลือกเพื่ออนุมัติแล้วบันทึก รายการที่ไม่เลือกจะยังรออนุมัติ"

msgid "Token exchange failed for provider %s."
msgstr "แลกเปลี่ยน token กับผู้ให้บริการ %s ไม่สำเร็จ"

msgid "Too many failed login attempts. Please try again later."
msgstr "พยายามเข้าสู่ระบบไม่สำเร็จหลายครั้งเกินไป กรุณาลองใหม่ภายหลัง"

msgid "Trusted providers"
msgstr "ผู้ให้บริการที่เชื่อถือ"

msgid "Type"
msgstr "ชนิด"

msgid "Uncheck inherit to set domains specific to this context."
msgstr "ยกเลิกการใช้ค่ากลางเพื่อกำหนดโดเมนเฉพาะบริบทนี้"

msgid "Used for radio and select only (one option per line). Ignored for other types."
msgstr "ใช้เฉพาะ radio และ select (หนึ่งตัวเลือกต่อบรรทัด) ชนิดอื่นจะไม่ใช้ค่านี้"

msgid "Used in [authorizenter_login context=\"…\"]. Leave blank to ignore this row."
msgstr "ใช้ใน [authorizenter_login context=\"…\"] เว้นว่างไว้เพื่อข้ามแถวนี้"

msgid "User must answer before continuing"
msgstr "ผู้ใช้ต้องตอบก่อนดำเนินการต่อ"

msgid "User provisioning"
msgstr "การสร้างผู้ใช้"

msgid "WordPress capability the user must have to enter this context."
msgstr "WordPress capability ที่ผู้ใช้ต้องมีเพื่อเข้าสู่บริบทนี้"

msgid "Yes"
msgstr "ใช่"

msgid "Yes — create users on first login"
msgstr "ใช่ — สร้างผู้ใช้เมื่อเข้าสู่ระบบครั้งแรก"

msgid "You are already signed in."
msgstr "คุณเข้าสู่ระบบอยู่แล้ว"

msgid "Your account does not have permission to sign in here."
msgstr "บัญชีของคุณไม่มีสิทธิ์เข้าสู่ระบบที่นี่"

msgid "Your account has been blocked from this site."
msgstr "บัญชีของคุณถูกบล็อกจากไซต์นี้"

msgid "Your account is awaiting approval to access this site."
msgstr "บัญชีของคุณกำลังรออนุมัติเพื่อเข้าใช้ไซต์นี้"

msgid "Your account is not permitted to sign in to this site."
msgstr "บัญชีของคุณไม่ได้รับอนุญาตให้เข้าสู่ระบบไซต์นี้"

