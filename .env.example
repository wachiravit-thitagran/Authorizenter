# Authorizenter — example environment file
#
# NOTE: Authorizenter stores provider credentials in the WordPress database via
# the admin settings screen (encrypted). This file is ONLY for local development
# helpers / CI and is intentionally NOT read by the plugin at runtime.
#
# Never commit a real .env — see .gitignore.

# Local WordPress URL used by dev scripts
WP_BASE_URL=http://localhost:8080

# Example provider placeholders (do not put real secrets here)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
